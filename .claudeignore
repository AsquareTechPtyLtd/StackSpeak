# ============================================
# StackSpeak — .claudeignore
# ============================================

# ── Secrets & Certificates ──────────────────
.env
.env.*
*.pem
*.key
*.p12
*.cer
*.der
*.mobileprovision
*.provisionprofile
ExportOptions.plist

# ── Xcode Build Artifacts ───────────────────
DerivedData/
build/
*.xcarchive
*.ipa
*.dSYM
*.dSYM.zip

# ── Xcode User State (noise) ────────────────
*.xcuserstate
*.xcuserdatad/
xcuserdata/
project.xcworkspace/xcuserdata/
*.xcworkspace/xcuserdata/

# ── Xcode Previews Cache ────────────────────

# ── Temporary / Planning ────────────────────
.planning/
.tmp/
_temp/
__Previews/
*.preview/

# ── Archives ───────────────────────────���────
*.tar.gz
*.tar
*.zip

# ── Claude Internal (do not recurse) ────────
.claude/

# ── Git ─────────────────────────────────────
.git/

# ── macOS Noise ─────────────────────────────
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
*.swp
*.swo

# ── Test Results & Coverage ──────────────────
TestResults/
*.xcresult
coverage/
*.lcov

# ── Swift Package Manager Cache ──────────────
.build/
.swiftpm/
*.resolved

# ── Logs ────────────────────────────────────
*.log
logs/
